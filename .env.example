# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# NOTION_TOKEN: Your secure Notion Internal Integration Token (secret_...)
NOTION_TOKEN=""

# NOTION_DATABASE_ID: The UUID of your portfolio table database in Notion
NOTION_DATABASE_ID=""

# SMTP CONFIGURATIONS (Optional, for instant email notifications)
# SMTP_HOST: The hostname of your mail server, e.g. smtp.gmail.com
SMTP_HOST=""
# SMTP_PORT: Usually 587 (TLS) or 465 (SSL)
SMTP_PORT=""
# SMTP_USER: Your mail account username, e.g., massivdev@gmail.com
SMTP_USER=""
# SMTP_PASSWORD: The secure App Password or mailbox access credentials
SMTP_PASSWORD=""
# NOTIFICATION_EMAIL: The destination email address to receive submission copies
NOTIFICATION_EMAIL="massivdev@gmail.com"

